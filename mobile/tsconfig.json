{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-native",
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/components/*": [
        "./src/shared/components/*"
      ]
    }
  },
  "ignores": [
    "node_modules",
    ".expo",
    "ios",
    "android",
    "app-example"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "tailwind.config.js",
    "nativewind-env.d.ts",
    "src/core/config/db.ts",
    "src/core/config/seeders.ts"
  ]
}